// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  QUALITY_MANAGER
  MANAGER
  ANALYST
}

enum StrategicObjectiveStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum StrategicObjectivePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InitiativeStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum IndicatorFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum NonConformitySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NonConformityStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum CorrectiveActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EffectivenessResult {
  EFFECTIVE
  INEFFECTIVE
  NEEDS_MONITORING
}

enum RiskStatus {
  OPEN
  MONITORING
  MITIGATED
  CLOSED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PreventiveActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id                          Int                 @id @default(autoincrement())
  name                        String
  email                       String              @unique
  password                    String
  role                        UserRole            @default(ANALYST)
  createdStrategicObjectives  StrategicObjective[] @relation("StrategicObjectiveCreatedBy")
  updatedStrategicObjectives  StrategicObjective[] @relation("StrategicObjectiveUpdatedBy")
  createdInitiatives          Initiative[]        @relation("InitiativeCreatedBy")
  updatedInitiatives          Initiative[]        @relation("InitiativeUpdatedBy")
  createdIndicators           Indicator[]         @relation("IndicatorCreatedBy")
  updatedIndicators           Indicator[]         @relation("IndicatorUpdatedBy")
  createdNonConformities      NonConformity[]     @relation("NonConformityCreatedBy")
  updatedNonConformities      NonConformity[]     @relation("NonConformityUpdatedBy")
  createdCorrectiveActions    CorrectiveAction[]  @relation("CorrectiveActionCreatedBy")
  updatedCorrectiveActions    CorrectiveAction[]  @relation("CorrectiveActionUpdatedBy")
  createdRisks                Risk[]              @relation("RiskCreatedBy")
  updatedRisks                Risk[]              @relation("RiskUpdatedBy")
  createdPreventiveActions    PreventiveAction[]  @relation("PreventiveActionCreatedBy")
  updatedPreventiveActions    PreventiveAction[]  @relation("PreventiveActionUpdatedBy")
  uploadedEvidences           Evidence[]          @relation("EvidenceUploadedBy")
  updatedEvidences            Evidence[]          @relation("EvidenceUpdatedBy")
  deletedEvidences            Evidence[]          @relation("EvidenceDeletedBy")
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
}

model StrategicObjective {
  id          Int                        @id @default(autoincrement())
  title       String
  description String?
  status      StrategicObjectiveStatus   @default(DRAFT)
  priority    StrategicObjectivePriority @default(MEDIUM)
  startsAt    DateTime?
  endsAt      DateTime?
  ownerId     Int?
  createdById Int?
  createdBy   User?                      @relation("StrategicObjectiveCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById Int?
  updatedBy   User?                      @relation("StrategicObjectiveUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  initiatives Initiative[]
  evidences   Evidence[]
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
}

model Initiative {
  id                   Int                @id @default(autoincrement())
  strategicObjectiveId Int
  strategicObjective   StrategicObjective @relation(fields: [strategicObjectiveId], references: [id], onDelete: Cascade)
  title                String
  description          String?
  status               InitiativeStatus   @default(PLANNED)
  dueAt                DateTime?
  ownerId              Int?
  createdById          Int?
  createdBy            User?              @relation("InitiativeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById          Int?
  updatedBy            User?              @relation("InitiativeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  evidences            Evidence[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Indicator {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  formula     String?
  unit        String?
  targetValue Float?
  frequency   IndicatorFrequency @default(MONTHLY)
  ownerId     Int?
  createdById Int?
  createdBy   User?              @relation("IndicatorCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById Int?
  updatedBy   User?              @relation("IndicatorUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  entries     IndicatorEntry[]
  evidences   Evidence[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model IndicatorEntry {
  id          Int       @id @default(autoincrement())
  indicatorId Int
  indicator   Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  value       Float
  collectedAt DateTime  @default(now())
  source      String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model NonConformity {
  id                Int                   @id @default(autoincrement())
  title             String
  description       String?
  severity          NonConformitySeverity @default(MEDIUM)
  status            NonConformityStatus   @default(OPEN)
  source            String?
  department        String?
  occurredAt        DateTime?
  ownerId           Int?
  createdById       Int?
  createdBy         User?                 @relation("NonConformityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById       Int?
  updatedBy         User?                 @relation("NonConformityUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  evidences         Evidence[]
  correctiveActions CorrectiveAction[]
  risks             Risk[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model CorrectiveAction {
  id                  Int                    @id @default(autoincrement())
  nonConformityId     Int
  nonConformity       NonConformity          @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
  title               String
  description         String?
  status              CorrectiveActionStatus @default(OPEN)
  dueAt               DateTime?
  completedAt         DateTime?
  ownerId             Int?
  createdById         Int?
  createdBy           User?                 @relation("CorrectiveActionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById         Int?
  updatedBy           User?                 @relation("CorrectiveActionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  evidences           Evidence[]
  effectivenessChecks EffectivenessCheck[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model EffectivenessCheck {
  id                 Int                 @id @default(autoincrement())
  correctiveActionId Int
  correctiveAction   CorrectiveAction    @relation(fields: [correctiveActionId], references: [id], onDelete: Cascade)
  checkedAt          DateTime            @default(now())
  result             EffectivenessResult
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Risk {
  id               Int        @id @default(autoincrement())
  nonConformityId  Int
  nonConformity    NonConformity @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  category         String?
  probability      Int
  impact           Int
  status           RiskStatus @default(OPEN)
  dueAt            DateTime?
  ownerId          Int?
  createdById      Int?
  createdBy        User?      @relation("RiskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById      Int?
  updatedBy        User?      @relation("RiskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  preventiveActions PreventiveAction[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model PreventiveAction {
  id               Int                    @id @default(autoincrement())
  riskId           Int
  risk             Risk                   @relation(fields: [riskId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  status           PreventiveActionStatus @default(OPEN)
  dueAt            DateTime?
  completedAt      DateTime?
  ownerId          Int?
  createdById      Int?
  createdBy        User?                  @relation("PreventiveActionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById      Int?
  updatedBy        User?                  @relation("PreventiveActionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
}

model Evidence {
  id                  Int                 @id @default(autoincrement())
  fileName            String
  label               String?
  objectKey           String              @unique
  bucketName          String
  contentType         String
  sizeBytes           Int
  uploadedById        Int?
  uploadedBy          User?               @relation("EvidenceUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  updatedById         Int?
  updatedBy           User?               @relation("EvidenceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedById         Int?
  deletedBy           User?               @relation("EvidenceDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  strategicObjectiveId Int?
  strategicObjective  StrategicObjective?  @relation(fields: [strategicObjectiveId], references: [id], onDelete: Cascade)
  initiativeId        Int?
  initiative          Initiative?         @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  indicatorId         Int?
  indicator           Indicator?          @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  nonConformityId     Int?
  nonConformity       NonConformity?      @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
  correctiveActionId  Int?
  correctiveAction    CorrectiveAction?   @relation(fields: [correctiveActionId], references: [id], onDelete: Cascade)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?
}
