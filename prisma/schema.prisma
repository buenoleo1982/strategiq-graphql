// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  QUALITY_MANAGER
  MANAGER
  ANALYST
}

enum StrategicObjectiveStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum StrategicObjectivePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IndicatorFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(ANALYST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StrategicObjective {
  id          Int                        @id @default(autoincrement())
  title       String
  description String?
  status      StrategicObjectiveStatus   @default(DRAFT)
  priority    StrategicObjectivePriority @default(MEDIUM)
  startsAt    DateTime?
  endsAt      DateTime?
  ownerId     Int?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
}

model Indicator {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  formula     String?
  unit        String?
  targetValue Float?
  frequency   IndicatorFrequency @default(MONTHLY)
  ownerId     Int?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}
