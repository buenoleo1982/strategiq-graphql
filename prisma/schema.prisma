// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  QUALITY_MANAGER
  MANAGER
  ANALYST
}

enum StrategicObjectiveStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum StrategicObjectivePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InitiativeStatus {
  PLANNED
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum IndicatorFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum NonConformitySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NonConformityStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum CorrectiveActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EffectivenessResult {
  EFFECTIVE
  INEFFECTIVE
  NEEDS_MONITORING
}

model User {
  id                Int        @id @default(autoincrement())
  name              String
  email             String     @unique
  password          String
  role              UserRole   @default(ANALYST)
  uploadedEvidences Evidence[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model StrategicObjective {
  id          Int                        @id @default(autoincrement())
  title       String
  description String?
  status      StrategicObjectiveStatus   @default(DRAFT)
  priority    StrategicObjectivePriority @default(MEDIUM)
  startsAt    DateTime?
  endsAt      DateTime?
  ownerId     Int?
  initiatives Initiative[]
  evidences   Evidence[]
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
}

model Initiative {
  id                   Int                @id @default(autoincrement())
  strategicObjectiveId Int
  strategicObjective   StrategicObjective @relation(fields: [strategicObjectiveId], references: [id], onDelete: Cascade)
  title                String
  description          String?
  status               InitiativeStatus   @default(PLANNED)
  dueAt                DateTime?
  ownerId              Int?
  evidences            Evidence[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Indicator {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  formula     String?
  unit        String?
  targetValue Float?
  frequency   IndicatorFrequency @default(MONTHLY)
  ownerId     Int?
  entries     IndicatorEntry[]
  evidences   Evidence[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model IndicatorEntry {
  id          Int       @id @default(autoincrement())
  indicatorId Int
  indicator   Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  value       Float
  collectedAt DateTime  @default(now())
  source      String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model NonConformity {
  id                Int                   @id @default(autoincrement())
  title             String
  description       String?
  severity          NonConformitySeverity @default(MEDIUM)
  status            NonConformityStatus   @default(OPEN)
  source            String?
  department        String?
  occurredAt        DateTime?
  ownerId           Int?
  evidences         Evidence[]
  correctiveActions CorrectiveAction[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model CorrectiveAction {
  id                  Int                    @id @default(autoincrement())
  nonConformityId     Int
  nonConformity       NonConformity          @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
  title               String
  description         String?
  status              CorrectiveActionStatus @default(OPEN)
  dueAt               DateTime?
  completedAt         DateTime?
  ownerId             Int?
  evidences           Evidence[]
  effectivenessChecks EffectivenessCheck[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model EffectivenessCheck {
  id                 Int                 @id @default(autoincrement())
  correctiveActionId Int
  correctiveAction   CorrectiveAction    @relation(fields: [correctiveActionId], references: [id], onDelete: Cascade)
  checkedAt          DateTime            @default(now())
  result             EffectivenessResult
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Evidence {
  id                  Int                @id @default(autoincrement())
  fileName            String
  label               String?
  objectKey           String             @unique
  bucketName          String
  contentType         String
  sizeBytes           Int
  uploadedById        Int?
  uploadedBy          User?              @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  strategicObjectiveId Int?
  strategicObjective  StrategicObjective? @relation(fields: [strategicObjectiveId], references: [id], onDelete: Cascade)
  initiativeId        Int?
  initiative          Initiative?        @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  indicatorId         Int?
  indicator           Indicator?         @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  nonConformityId     Int?
  nonConformity       NonConformity?     @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
  correctiveActionId  Int?
  correctiveAction    CorrectiveAction?  @relation(fields: [correctiveActionId], references: [id], onDelete: Cascade)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}
