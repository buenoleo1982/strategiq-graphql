{
  "name": "backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "start": "bun src/index.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "e2e:setup": "bun prisma/seed/e2e.ts",
    "schema:generate": "NEXUS_SHOULD_GENERATE_ARTIFACTS=true NODE_ENV=development bun src/graphql/schema.ts",
    "lint": "biome check .",
    "lint:ci": "biome check package.json README.md .github/workflows src/graphql/types/indicator-entry src/graphql/resolvers/indicator-entry src/service/indicator-entry-csv.ts src/__tests__/graphql/IndicatorEntryResolvers.test.ts",
    "lint:unsafe": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "check": "bun run lint && tsc --noEmit && bun run test:run",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@as-integrations/fastify": "^3.1.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^10.0.0",
    "@prisma/client": "^6.17.1",
    "aws4fetch": "^1.0.20",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.6.1",
    "graphql": "^16.11.0",
    "ioredis": "^5.8.1",
    "jose": "^6.1.0",
    "minio": "^8.0.7",
    "nexus": "^1.3.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "pino-roll": "^4.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^24.9.1",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^17.2.3",
    "prisma": "^6.17.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.2.22"
}
